generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  email            String    @unique
  /** Unicité assurée côté API admin ; pas d’index unique Prisma (plusieurs `null` en Mongo). */
  matricule        String?
  passwordHash     String
  nom              String
  prenom           String
  role             String
  agenceId         String?
  agencesAutorisees String[]
  modulesAutorises String[]
  produitsAutorises String[]
  actif            Boolean   @default(true)
  currentSessionId String?
  derniereConnexion DateTime?
  lastActivityAt   DateTime?
  resetPasswordTokenHash String?
  resetPasswordExpiresAt DateTime?
  /** Dernier changement de mot de passe (politique de rotation mensuelle). */
  passwordChangedAt DateTime?
  /** Dernier mois (UTC, format YYYY-MM) pour lequel l’e-mail automatique de fin de mois avec lien de réinitialisation a été envoyé. */
  passwordResetReminderSentForMonth String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  @@map("users")
  @@index([matricule], map: "idx_matricule")
  @@index([role], map: "idx_role")
  @@index([actif], map: "idx_actif")
}

model Counter {
  id  String @id @map("_id")
  seq Int    @default(0)

  @@map("counters")
}

model Concessionnaire {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  /** Attribué après validation N1 de l'inscription ; null en brouillon / soumis. */
  codePdv         String?   @unique
  /** Parcours d'inscription : DOSSIER_EN_COURS → SOUMIS → N1 (code PDV) → caution payée → VALIDE. Legacy : VALIDE. */
  inscriptionStatut String  @default("VALIDE")
  nom             String?
  prenom          String?
  /** Code terminal métier (saisie libre, distinct du code PDV généré). */
  codeTerminal    String?
  /** Code concessionnaire métier (saisie libre). */
  codeConcessionnaire String?
  nomComplet      String?
  raisonSociale   String
  cniNumero       String?
  photoUrl        String?
  email           String?
  telephonePrincipal String?
  telephoneSecondaire String?
  telephone       String?
  adresse         String?
  ville           String?
  codePostal      String?
  agenceId        String?
  /** Client Lonaci d'origine (parcours client → promotion PDV). */
  sourceLonaciClientId String?
  produitsAutorises String[]
  statut          String
  statutBancarisation String?
  /** 8.1 — Collecte RIB : EN_ATTENTE_RIB | RIB_FOURNI | RIB_VALIDE */
  etatRib         String?
  ribDemandeAt    DateTime?
  ribFourniAt     DateTime?
  ribValideAt     DateTime?
  /** 8.2 — Horodatage intégration paiement LONACI */
  bancariseAt     DateTime?
  ribPieceId      String?
  compteBancaire  String?
  banqueEtablissement String?
  gps             Json?
  /** Checklist pièces justificatives (modèle produit) pendant l'inscription. */
  documentChecklist Json?
  inscriptionSoumisAt DateTime?
  inscriptionValideN1At DateTime?
  inscriptionRejetMotif String?
  piecesJointes   Json      @default("[]")
  observations    String?
  notesInternes   String?
  createdByUserId String
  updatedByUserId String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@map("concessionnaires")
  @@index([agenceId], map: "idx_agence")
  @@index([sourceLonaciClientId], map: "idx_source_lonaci_client")
  @@index([statut], map: "idx_statut")
  @@index([inscriptionStatut], map: "idx_inscription_statut")
  @@index([statutBancarisation], map: "idx_statut_bancarisation")
  @@index([deletedAt], map: "idx_deleted")
  @@index([raisonSociale], map: "idx_raison")
  @@index([agenceId, statut, statutBancarisation, deletedAt], map: "idx_filters_combo")
}

model BancarisationRequest {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  concessionnaireId   String
  agenceId            String?
  produitCode         String?
  statutActuel        String
  nouveauStatut       String
  compteBancaire      String?
  banqueEtablissement String?
  dateEffet           DateTime
  justificatif        Json?
  status              String
  validationComment   String?
  validatedByUserId   String?
  validatedAt         DateTime?
  createdByUserId     String
  updatedByUserId     String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("bancarisation_requests")
  @@index([status], map: "idx_status")
  @@index([agenceId], map: "idx_agence")
  @@index([concessionnaireId, status], map: "idx_concessionnaire_status")
  @@index([dateEffet], map: "idx_date_effet")
}

model Contrat {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  reference        String   @unique
  annexeReference  String?
  concessionnaireId String?
  lonaciClientId    String?
  produitCode      String
  operationType    String
  status           String
  dateEffet        DateTime
  dossierId        String
  createdByUserId  String
  updatedByUserId  String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  @@map("contrats")
  @@unique([dossierId, produitCode], map: "uniq_dossier_produit")
  @@index([dossierId], map: "idx_dossier")
  @@index([concessionnaireId, produitCode, status, deletedAt], map: "idx_unique_active_check")
  @@index([lonaciClientId, produitCode, status, deletedAt], map: "idx_client_active_check")
}

/** Comptes clients / tiers (distinct des concessionnaires PDV). */
model LonaciClient {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  code            String
  /** Particulier ou personne morale (entreprise). */
  categorie       String    @default("PARTICULIER")
  raisonSociale   String
  /** Nom et prénom(s) du client (identité principale). */
  nomComplet      String?
  cniNumero       String?
  nomContact      String?
  email           String?
  telephone       String?
  adresse         String?
  ville           String?
  codePostal      String?
  agenceId        String?
  produitsAutorises String[]
  statut          String
  /** Validation création par le Chef de section (N1). */
  validationN1At        DateTime?
  validationN1ByUserId  String?
  rejetMotif            String?
  rejetAt               DateTime?
  /** Pièces justificatives cochées (référentiel produit). */
  documentChecklist     Json?
  notes           String?
  createdByUserId String
  updatedByUserId String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@map("clients")
  @@unique([agenceId, code], map: "uniq_client_agence_code")
  @@index([agenceId], map: "idx_client_agence")
  @@index([statut], map: "idx_client_statut")
  @@index([categorie], map: "idx_client_categorie")
  @@index([deletedAt], map: "idx_client_deleted")
  @@index([raisonSociale], map: "idx_client_raison")
  @@index([nomComplet], map: "idx_client_nom_complet")
}
