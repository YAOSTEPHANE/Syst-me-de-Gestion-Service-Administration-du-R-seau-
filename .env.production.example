# ============================================
# MODELE .env.production (A REMPLIR)
# ============================================
# Ne jamais committer de vrais secrets.
# Copier ce fichier en .env.production et remplacer toutes les valeurs __CHANGE_ME__.

# ----------------------------
# Obligatoire
# ----------------------------
DATABASE_URL="mongodb+srv://__CHANGE_ME_USER__:__CHANGE_ME_PASSWORD__@__CHANGE_ME_CLUSTER__/lonaci?retryWrites=true&w=majority"
JWT_SECRET="__CHANGE_ME_LONG_RANDOM_SECRET_MIN_32_CHARS__"
CRON_SECRET="__CHANGE_ME_LONG_RANDOM_SECRET__"
NEXT_PUBLIC_APP_URL="https://__CHANGE_ME_PUBLIC_DOMAIN__"

# ----------------------------
# Optionnel Mongo natif
# (si absent, DATABASE_URL est reutilisee)
# ----------------------------
# MONGODB_URI="mongodb+srv://__CHANGE_ME_USER__:__CHANGE_ME_PASSWORD__@__CHANGE_ME_CLUSTER__/lonaci?retryWrites=true&w=majority"
# MONGODB_DB="lonaci"

# ----------------------------
# CORS (recommande en production)
# CSV d'origines autorisees
# ----------------------------
CORS_ALLOWED_ORIGINS="https://__CHANGE_ME_PUBLIC_DOMAIN__"

# ----------------------------
# SMTP (recommande en production)
# ----------------------------
SMTP_HOST="__CHANGE_ME_SMTP_HOST__"
SMTP_PORT="587"
SMTP_USER="__CHANGE_ME_SMTP_USER__"
SMTP_PASS="__CHANGE_ME_SMTP_PASSWORD__"
EMAIL_FROM="noreply@__CHANGE_ME_PUBLIC_DOMAIN__"

# ----------------------------
# GPR API (si utilisee)
# ----------------------------
GPR_API_ENDPOINT="https://__CHANGE_ME_GPR_ENDPOINT__"
GPR_API_KEY="__CHANGE_ME_GPR_API_KEY__"
GPR_API_TIMEOUT_MS="15000"
GPR_API_MAX_RETRIES="3"

# ----------------------------
# Front/public
# ----------------------------
NEXT_PUBLIC_APP_NAME="LONACI"
NEXT_PUBLIC_CRON_SCHEDULE_LABEL="08h00 locale"
# Autorisation import Excel par module (vide = politique par defaut)
# NEXT_PUBLIC_IMPORT_ALLOW_EXCEL_MODULES="CONTRATS,CAUTIONS"

# ----------------------------
# Durcissement securite recommande
# ----------------------------
RATE_LIMIT_FAIL_CLOSED="true"
ENABLE_CSP_ENFORCE="true"
PROXY_RATE_LIMIT_ENABLED="false"

# ----------------------------
# Operationnel / logs
# ----------------------------
SKIP_PROD_ENV_CONSOLE="true"
BACKUP_DIR="backups"
BACKUP_RETENTION_DAYS="14"
