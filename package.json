{
  "name": "lonaci",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev --turbopack --hostname 127.0.0.1",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "test:all": "npm run test && npx tsc --noEmit && npm run check:api-routes && npm run check:api-zod && npm run build && npm run lint && npm run test:e2e",
    "check:api-routes": "tsx scripts/check-api-route-auth.ts",
    "check:api-zod": "tsx scripts/check-api-zod-validation.ts",
    "verify:db": "tsx scripts/verify-db-connection.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "seed:test": "tsx scripts/seed-test-data.ts",
    "seed": "npm run seed:test",
    "import:data": "tsx scripts/import-data.ts",
    "backup:data": "tsx scripts/backup-data.ts",
    "restore:data": "tsx scripts/restore-data.ts",
    "backup:task:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/register-backup-task.ps1"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "jose": "^6.2.2",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "mongodb": "^6.20.0",
    "next": "^16.2.4",
    "nodemailer": "^8.0.4",
    "pdfjs-dist": "^5.5.207",
    "pdfkit": "^0.18.0",
    "prisma": "6.19.3",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
