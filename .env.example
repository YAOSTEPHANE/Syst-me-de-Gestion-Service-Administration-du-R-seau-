# Copier vers .env.local : cp .env.example .env.local (ou équivalent Windows)
#
# =========================
# CHECKLIST .ENV PRODUCTION
# =========================
# [OBLIGATOIRE]
# - DATABASE_URL
# - JWT_SECRET (>= 32 caracteres)
# - CRON_SECRET
# - NEXT_PUBLIC_APP_URL (URL publique HTTPS)
#
# [FORTEMENT RECOMMANDE]
# - SMTP_HOST / SMTP_PORT / SMTP_USER / SMTP_PASS / EMAIL_FROM
# - CORS_ALLOWED_ORIGINS (whitelist explicite, CSV)
# - RATE_LIMIT_FAIL_CLOSED=true
# - ENABLE_CSP_ENFORCE=true
#
# [SECURITE / DURCISSEMENT]
# - PROXY_RATE_LIMIT_ENABLED=false (recommande en prod multi-instance)
# - SKIP_PROD_ENV_CONSOLE=true (optionnel, logs CI plus propres)

# Prisma (obligatoire pour les utilisateurs, etc.)
# Exemple (ne jamais committer de vrais secrets) :
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/lonaci?retryWrites=true&w=majority"

# Client Mongo natif (journaux d’auth) : facultatif si DATABASE_URL pointe déjà vers le même cluster —
# le code réutilise alors DATABASE_URL et le nom de base dans l’URL (ex. .../lonaci).
# MONGODB_URI="mongodb+srv://..."
# MONGODB_DB=lonaci
# Si querySrv ECONNREFUSED (DNS d’entreprise / VPN) : conversion auto srv → standard au démarrage
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
# MONGODB_SRV_TO_STANDARD=true
# Ou URI standard copiée depuis Atlas (Connect → Drivers → Standard) :
# DATABASE_URL_STANDARD="mongodb://..."

# Sans DATABASE_URL ni MONGODB_URI en dev : repli mongodb://127.0.0.1:27017 (Mongo local).

# Données de démonstration (concessionnaires PDV-DEMO-*, dossiers, contrats, cautions, succession…)
# Nécessite au moins un utilisateur (ex. npm run seed:admin).
# Raccourci : npm run seed:test  (admin + démo en une commande)
# ALLOW_SEED_DEMO=true
# SEED_DEMO_RESET=true   # supprime l’ancien jeu PDV-DEMO-* puis régénère

# Secret pour signer les JWT (≥ 32 caractères recommandé)
JWT_SECRET=remplacez-par-un-secret-long-et-aleatoire-en-production

# Optionnel
# NEXT_PUBLIC_APP_NAME=ADMR

# CORS API (CSV d'origines autorisées, ex:
# CORS_ALLOWED_ORIGINS=https://app.exemple.com,https://admin.exemple.com)
# Sans valeur en prod, les requêtes CORS cross-site sont refusées.
# CORS_ALLOWED_ORIGINS=

# --- Cron planifié (POST) : Authorization: Bearer <CRON_SECRET> ou x-cron-secret ---
# CRON_SECRET=generez-un-secret-long-aleatoire
# Quotidien : POST /api/cron/daily-jobs
# Fin de mois (UTC) : POST /api/cron/monthly-password-reminders — envoie un lien de réinitialisation aux utilisateurs actifs (SMTP requis ; idempotence par mois).
# URL publique des liens dans les e-mails :
# NEXT_PUBLIC_APP_URL=https://votre-app.example.com
# Libellé affiché dans le module Rapports (informatif uniquement)
# NEXT_PUBLIC_CRON_SCHEDULE_LABEL=08h00 locale

# --- CSP : à true au moment du build Next pour appliquer la CSP en mode bloquant ---
# ENABLE_CSP_ENFORCE=false
# Recommandé en prod après validation UI : ENABLE_CSP_ENFORCE=true

# --- Import fichiers (frontend) ---
# Modules critiques en mode strict par défaut: CONTRATS, CAUTIONS, BANCARISATION, PDV_INTEGRATIONS
# Pour réactiver temporairement Excel (.xlsx/.xls) sur certains modules:
# NEXT_PUBLIC_IMPORT_ALLOW_EXCEL_MODULES=CONTRATS,CAUTIONS
# Pour autoriser Excel partout (mode legacy de transition): NEXT_PUBLIC_IMPORT_ALLOW_EXCEL_MODULES=*

# --- E-mail (recommandé en production) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@example.com

# --- GPR API (Phase 2 : synchro directe) ---
# URL endpoint recevant les enregistrements validés GPR (POST JSON)
# GPR_API_ENDPOINT=https://gpr.example.com/api/v1/registrations
# Clé d'authentification Bearer
# GPR_API_KEY=remplacez-par-votre-cle-api-gpr
# Timeout HTTP en ms (défaut: 15000)
# GPR_API_TIMEOUT_MS=15000
# Nombre max de tentatives par déclenchement (défaut: 3)
# GPR_API_MAX_RETRIES=3

# --- Premier compte « admin » (rôle CHEF_SERVICE) — développement / installation ---
# 1) Mettre ALLOW_SEED_ADMIN=true puis : npm run seed:admin
# 2) Se connecter sur /login avec les identifiants ci-dessous (ou les vôtres)
# ALLOW_SEED_ADMIN=true
# ADMIN_EMAIL=admin@lonaci.ci
# ADMIN_PASSWORD=Admin@123456
# ADMIN_NOM=Admin
# ADMIN_PRENOM=ADMR

# --- Logs : masquer les avertissements prod (SMTP, CRON, rate limit) pendant next build / CI ---
# SKIP_PROD_ENV_CONSOLE=true

# --- Sauvegarde des données (scripts npm run backup:data / restore:data) ---
# Dossier de destination des sauvegardes (relatif à la racine du projet)
# BACKUP_DIR=backups
# Rétention automatique en jours (les sauvegardes plus anciennes sont supprimées)
# BACKUP_RETENTION_DAYS=14

# --- Rate limiting (Mongo) — login, reset MDP, signatures publiques, etc. ---
# Développement : fail-open si le store Mongo est en erreur (défaut implicite hors production).
# Production : fail-closed par défaut sauf si RATE_LIMIT_FAIL_CLOSED=false (fail-open explicite).
# RATE_LIMIT_FAIL_CLOSED=true

# --- Proxy rate-limit (memoire locale process) ---
# En prod multi-instance, laissez a false (ou non defini) et utilisez le rate-limit Mongo central.
# En local/dev, active par defaut.
# PROXY_RATE_LIMIT_ENABLED=false
