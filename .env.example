# Copier vers .env.local : cp .env.example .env.local (ou équivalent Windows)

# Prisma (obligatoire pour les utilisateurs, etc.)
# Exemple (ne jamais committer de vrais secrets) :
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/lonaci?retryWrites=true&w=majority"

# Client Mongo natif (journaux d’auth) : facultatif si DATABASE_URL pointe déjà vers le même cluster —
# le code réutilise alors DATABASE_URL et le nom de base dans l’URL (ex. .../lonaci).
# MONGODB_URI="mongodb+srv://..."
# MONGODB_DB=lonaci

# Sans DATABASE_URL ni MONGODB_URI en dev : repli mongodb://127.0.0.1:27017 (Mongo local).

# Données de démonstration (concessionnaires PDV-DEMO-*, dossiers, contrats, cautions, succession…)
# Nécessite au moins un utilisateur (ex. npm run seed:admin).
# Raccourci : npm run seed:test  (admin + démo en une commande)
# ALLOW_SEED_DEMO=true
# SEED_DEMO_RESET=true   # supprime l’ancien jeu PDV-DEMO-* puis régénère

# Secret pour signer les JWT (≥ 32 caractères recommandé)
JWT_SECRET=remplacez-par-un-secret-long-et-aleatoire-en-production

# Optionnel
# NEXT_PUBLIC_APP_NAME=ADMR

# --- Cron planifié (POST /api/cron/daily-jobs) : Bearer ou x-cron-secret ---
# CRON_SECRET=generez-un-secret-long-aleatoire

# --- CSP : à true au moment du build Next pour appliquer la CSP en mode bloquant ---
# ENABLE_CSP_ENFORCE=false

# --- E-mail (recommandé en production) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@example.com

# --- GPR API (Phase 2 : synchro directe) ---
# URL endpoint recevant les enregistrements validés GPR (POST JSON)
# GPR_API_ENDPOINT=https://gpr.example.com/api/v1/registrations
# Clé d'authentification Bearer
# GPR_API_KEY=remplacez-par-votre-cle-api-gpr
# Timeout HTTP en ms (défaut: 15000)
# GPR_API_TIMEOUT_MS=15000
# Nombre max de tentatives par déclenchement (défaut: 3)
# GPR_API_MAX_RETRIES=3

# --- Premier compte « admin » (rôle CHEF_SERVICE) — développement / installation ---
# 1) Mettre ALLOW_SEED_ADMIN=true puis : npm run seed:admin
# 2) Se connecter sur /login avec les identifiants ci-dessous (ou les vôtres)
# ALLOW_SEED_ADMIN=true
# ADMIN_EMAIL=admin@lonaci.ci
# ADMIN_PASSWORD=Admin@123456
# ADMIN_NOM=Admin
# ADMIN_PRENOM=ADMR

# --- Logs : masquer les avertissements prod (SMTP, CRON, rate limit) pendant next build / CI ---
# SKIP_PROD_ENV_CONSOLE=true

# --- Rate limiting (Mongo) — route signatures publiques, etc. ---
# Par défaut, en cas d’erreur Mongo sur le compteur : fail-open (la requête est autorisée).
# Mettre à true pour refuser les requêtes si le store de rate limit est indisponible (fail-closed).
# RATE_LIMIT_FAIL_CLOSED=true
